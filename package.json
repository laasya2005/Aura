{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm db:generate && turbo dev worker",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @aura/db generate",
    "db:migrate": "pnpm --filter @aura/db migrate",
    "db:seed": "pnpm --filter @aura/db seed",
    "db:studio": "pnpm --filter @aura/db studio",
    "worker": "pnpm --filter @aura/api worker"
  },
  "devDependencies": {
    "dotenv-cli": "^7.3.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.0"
  }
}
